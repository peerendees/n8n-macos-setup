# n8n Docker Compose Configuration
# Kopiere diese Datei nach ~/n8n/docker-compose.yml
# Passe die .env Datei mit deinen Werten an

# HINWEIS: "version: '3.8'" ist deprecated - kann weggelassen werden
# Falls Warnung erscheint, einfach entfernen

version: '3.8'

services:
  # PostgreSQL 15 - Hauptdatenbank für n8n
  postgres:
    image: postgres:15-alpine
    container_name: threema_postgres
    restart: unless-stopped
    environment:
      POSTGRES_DB: ${POSTGRES_DB:-threema_db}
      POSTGRES_USER: ${POSTGRES_USER:-n8n_user}
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD}  # ← In .env setzen!
      POSTGRES_INITDB_ARGS: "--encoding=UTF8 --locale=C"
    volumes:
      - postgres_data:/var/lib/postgresql/data
      - ./init.sql:/docker-entrypoint-initdb.d/init.sql:ro  # Optional: Initialisierungs-SQL
      - ./backups:/backups  # Für manuelle Backups
    ports:
      - "127.0.0.1:5432:5432"  # Nur localhost, nicht öffentlich!
    networks:
      - threema_network
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ${POSTGRES_USER:-n8n_user} -d ${POSTGRES_DB:-threema_db}"]
      interval: 30s
      timeout: 10s
      retries: 3

  # Redis 7 - Cache und Queue-System
  redis:
    image: redis:7-alpine
    container_name: threema_redis
    restart: unless-stopped
    command: redis-server --requirepass "${REDIS_PASSWORD}" --appendonly yes --appendfsync everysec
    volumes:
      - redis_data:/data
    ports:
      - "127.0.0.1:6379:6379"  # Nur localhost!
    networks:
      - threema_network
    healthcheck:
      test: ["CMD", "redis-cli", "--raw", "incr", "ping"]
      interval: 30s
      timeout: 10s
      retries: 3

  # n8n - Workflow Automation Engine
  n8n:
    image: n8nio/n8n:latest  # Oder spezifische Version: n8nio/n8n:1.116.2
    container_name: threema_n8n
    restart: unless-stopped
    environment:
      # === Datenbank-Konfiguration ===
      DB_TYPE: postgresdb
      DB_POSTGRESDB_HOST: postgres
      DB_POSTGRESDB_PORT: 5432
      DB_POSTGRESDB_DATABASE: ${POSTGRES_DB:-threema_db}
      DB_POSTGRESDB_USER: ${POSTGRES_USER:-n8n_user}
      DB_POSTGRESDB_PASSWORD: ${POSTGRES_PASSWORD}
      DB_POSTGRESDB_SCHEMA: n8n
      
      # === Redis-Konfiguration ===
      QUEUE_BULL_REDIS_HOST: redis
      QUEUE_BULL_REDIS_PORT: 6379
      QUEUE_BULL_REDIS_PASSWORD: ${REDIS_PASSWORD}
      
      # === n8n-Grundkonfiguration ===
      N8N_HOST: ${N8N_HOST:-localhost}  # Für produktiv: deine Domain
      N8N_PORT: 5678
      N8N_PROTOCOL: http  # Für produktiv mit SSL: https
      WEBHOOK_URL: ${WEBHOOK_URL}  # http://localhost:5678 oder https://deine-domain.de
      
      # === Sicherheit & Authentifizierung ===
      N8N_BASIC_AUTH_ACTIVE: true  # Aktiviert Login-Schutz
      N8N_BASIC_AUTH_USER: ${N8N_AUTH_USER}  # ← In .env setzen!
      N8N_BASIC_AUTH_PASSWORD: ${N8N_AUTH_PASSWORD}  # ← In .env setzen!
      
      # === Optionale Integrationen ===
      # Threema Gateway (falls benötigt)
      THREEMA_GATEWAY_ID: ${THREEMA_GATEWAY_ID}
      THREEMA_GATEWAY_SECRET: ${THREEMA_GATEWAY_SECRET}
      
      # Azure OpenAI (falls benötigt)
      AZURE_OPENAI_API_KEY: ${AZURE_OPENAI_API_KEY}
      AZURE_OPENAI_ENDPOINT: ${AZURE_OPENAI_ENDPOINT}
      AZURE_OPENAI_DEPLOYMENT_NAME: ${AZURE_OPENAI_DEPLOYMENT_NAME}
      AZURE_OPENAI_API_VERSION: ${AZURE_OPENAI_API_VERSION:-2023-05-15}
      
      # === Logging & Compliance ===
      N8N_LOG_LEVEL: ${LOG_LEVEL:-info}  # debug, info, warn, error
      N8N_LOG_OUTPUT: console,file
      N8N_LOG_FILE_LOCATION: /home/node/.n8n/logs/
      
      # === Datenaufbewahrung (DSGVO) ===
      EXECUTIONS_DATA_PRUNE: true  # Auto-Löschung alter Executions
      EXECUTIONS_DATA_MAX_AGE: ${DATA_RETENTION_DAYS:-30}  # Tage
      ENABLE_AUDIT_LOGGING: ${ENABLE_AUDIT_LOGGING:-true}
      AUDIT_LOG_RETENTION_DAYS: ${AUDIT_LOG_RETENTION_DAYS:-2555}  # ~7 Jahre
      ENABLE_DATA_ENCRYPTION: ${ENABLE_DATA_ENCRYPTION:-true}
      
      # === Entwicklung/Produktion ===
      NODE_ENV: ${NODE_ENV:-development}  # Für produktiv: production
      DEBUG_MODE: ${DEBUG_MODE:-false}
      
    volumes:
      - n8n_data:/home/node/.n8n  # Workflows, Credentials, Executions
      - ./custom_nodes:/home/node/.n8n/custom  # Eigene Nodes (optional)
      - ./logs:/home/node/.n8n/logs  # Log-Dateien
    ports:
      - "127.0.0.1:5678:5678"  # n8n Web-UI
    networks:
      - threema_network
    depends_on:
      postgres:
        condition: service_healthy
      redis:
        condition: service_healthy
    healthcheck:
      test: ["CMD-SHELL", "wget --no-verbose --tries=1 --spider http://localhost:5678/healthz || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 3

  # pgAdmin - Optionales PostgreSQL Management Tool
  # Start mit: docker-compose --profile tools up -d
  pgadmin:
    image: dpage/pgadmin4:latest
    container_name: threema_pgadmin
    restart: unless-stopped
    environment:
      PGADMIN_DEFAULT_EMAIL: ${PGADMIN_EMAIL:-admin@local.dev}
      PGADMIN_DEFAULT_PASSWORD: ${PGADMIN_PASSWORD}
      PGADMIN_CONFIG_SERVER_MODE: 'False'
      PGADMIN_CONFIG_MASTER_PASSWORD_REQUIRED: 'True'
    volumes:
      - pgadmin_data:/var/lib/pgadmin
    ports:
      - "127.0.0.1:5050:80"  # pgAdmin Web-UI
    networks:
      - threema_network
    depends_on:
      - postgres
    profiles:
      - tools  # Nur starten wenn --profile tools angegeben

# Docker Volumes - Persistente Datenspeicherung
volumes:
  postgres_data:
    driver: local
  redis_data:
    driver: local
  n8n_data:
    driver: local
  pgadmin_data:
    driver: local

# Docker Network - Interne Kommunikation
networks:
  threema_network:
    driver: bridge
    internal: false  # Zugriff auf Internet erlaubt

# ========================================
# VERWENDUNG
# ========================================
#
# 1. Kopiere diese Datei nach ~/n8n/docker-compose.yml
# 2. Erstelle .env Datei (siehe env.template)
# 3. Start: docker-compose up -d
# 4. Stop: docker-compose down
# 5. Logs: docker-compose logs -f n8n
# 6. Neu starten: docker-compose restart n8n
#
# ========================================
# PORT-ANPASSUNGEN (falls bereits belegt)
# ========================================
#
# Falls Ports bereits belegt sind, ändere:
# - n8n: "5679:5678" statt "5678:5678"
# - postgres: "5433:5432" statt "5432:5432"
# - redis: "6380:6379" statt "6379:6379"
#
# WICHTIG: Nur linke Seite ändern (Host-Port)!
#
# ========================================
# PRODUKTION (öffentlich zugänglich)
# ========================================
#
# Für produktiven Einsatz:
# 1. Reverse Proxy einrichten (nginx/Caddy)
# 2. SSL-Zertifikat (Let's Encrypt)
# 3. N8N_PROTOCOL=https
# 4. WEBHOOK_URL=https://deine-domain.de
# 5. Ports nur an Reverse Proxy binden
# 6. NODE_ENV=production
#
# ========================================


