# n8n Environment Configuration
# ========================================
# ANLEITUNG:
# 1. Kopiere diese Datei nach ~/n8n/.env
# 2. Ersetze ALLE Platzhalter mit echten Werten
# 3. Generiere sichere Passwörter (siehe unten)
# 4. NIEMALS diese Datei in Git committen!
# ========================================

# =====================================
# POSTGRESQL DATENBANK
# =====================================

# Datenbank-Name (Standard: threema_db)
POSTGRES_DB=threema_db

# Datenbank-Benutzer (Standard: n8n_user)
POSTGRES_USER=n8n_user

# Datenbank-Passwort ← ERSETZEN!
# Sicheres Passwort generieren: openssl rand -base64 32
POSTGRES_PASSWORD=HIER_SICHERES_PASSWORT_EINTRAGEN

# =====================================
# REDIS CACHE
# =====================================

# Redis-Passwort ← ERSETZEN!
REDIS_PASSWORD=HIER_SICHERES_PASSWORT_EINTRAGEN

# =====================================
# n8n AUTHENTIFIZIERUNG
# =====================================

# Hostname (für lokale Entwicklung: localhost)
# Für Produktion: deine Domain ohne http://
N8N_HOST=localhost

# Webhook-URL (vollständige URL inkl. Protokoll)
# Lokal: http://localhost:5678
# Produktion: https://deine-domain.de
WEBHOOK_URL=http://localhost:5678

# n8n Login-Benutzername ← ERSETZEN!
N8N_AUTH_USER=admin

# n8n Login-Passwort ← ERSETZEN!
# Mindestens 12 Zeichen empfohlen
N8N_AUTH_PASSWORD=HIER_SICHERES_PASSWORT_EINTRAGEN

# =====================================
# OPTIONAL: THREEMA GATEWAY
# =====================================
# Falls du Threema-Integration nutzt

# Threema Gateway ID (8 Zeichen) ← EINTRAGEN falls benötigt
THREEMA_GATEWAY_ID=*ABCD1234

# Threema Gateway Secret ← EINTRAGEN falls benötigt
THREEMA_GATEWAY_SECRET=*secret_hier_eintragen

# =====================================
# OPTIONAL: AZURE OPENAI
# =====================================
# Falls du Azure OpenAI nutzt

# Azure OpenAI API Key ← EINTRAGEN falls benötigt
AZURE_OPENAI_API_KEY=*api_key_hier_eintragen

# Azure OpenAI Endpoint ← EINTRAGEN falls benötigt
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/

# Azure OpenAI Deployment Name ← EINTRAGEN falls benötigt
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4

# Azure OpenAI API Version (Standard: 2023-05-15)
AZURE_OPENAI_API_VERSION=2023-05-15

# =====================================
# OPTIONAL: PGADMIN (PostgreSQL GUI)
# =====================================
# Nur wenn du pgAdmin nutzen möchtest
# Start mit: docker-compose --profile tools up -d

# pgAdmin Login-Email ← ERSETZEN falls verwendet
PGADMIN_EMAIL=admin@local.dev

# pgAdmin Login-Passwort ← ERSETZEN falls verwendet
PGADMIN_PASSWORD=HIER_PASSWORT_EINTRAGEN

# =====================================
# n8n ERWEITERTE EINSTELLUNGEN
# =====================================

# Log-Level (debug, info, warn, error)
LOG_LEVEL=info

# Datenaufbewahrung in Tagen (DSGVO)
DATA_RETENTION_DAYS=30

# Audit-Log Aufbewahrung in Tagen
AUDIT_LOG_RETENTION_DAYS=2555

# Aktiviere Audit-Logging (true/false)
ENABLE_AUDIT_LOGGING=true

# Aktiviere Datenverschlüsselung (true/false)
ENABLE_DATA_ENCRYPTION=true

# Umgebung (development/production)
NODE_ENV=development

# Debug-Modus (true/false)
DEBUG_MODE=false

# =====================================
# WEITERE INTEGRATIONEN (Optional)
# =====================================

# Hier kannst du weitere API-Keys/Secrets eintragen:

# OpenAI API Key (nicht Azure)
# OPENAI_API_KEY=sk-...

# SendGrid API Key
# SENDGRID_API_KEY=SG...

# Slack Bot Token
# SLACK_BOT_TOKEN=xoxb-...

# Google OAuth Credentials
# GOOGLE_CLIENT_ID=...
# GOOGLE_CLIENT_SECRET=...

# =====================================
# WICHTIGE HINWEISE
# =====================================
#
# 1. SICHERE PASSWÖRTER GENERIEREN:
#    openssl rand -base64 32
#    
# 2. NIEMALS IN GIT COMMITTEN:
#    Diese Datei muss in .gitignore sein!
#
# 3. BACKUP SICHER AUFBEWAHREN:
#    Kopie auf verschlüsseltem USB-Stick
#    Oder in Passwort-Manager
#
# 4. REGELMÄSSIG PASSWÖRTER ROTIEREN:
#    Alle 90 Tage empfohlen
#
# 5. ZUGRIFF BESCHRÄNKEN:
#    chmod 600 .env
#    (Nur Eigentümer kann lesen/schreiben)
#
